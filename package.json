{
  "name": "@hopla/ifreeicloud",
  "version": "1.0.0",
  "description": "TypeScript client for the iFreeiCloud IMEI / iCloud / carrier check API",
  "author": "Julio Moreno",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    }
  },
  "bin": {
    "ifreeicloud-skill-install": "bin/ifreeicloud-skill-install",
    "ifreeicloud-skill-uninstall": "bin/ifreeicloud-skill-uninstall"
  },
  "files": [
    "dist",
    "docs",
    "skills",
    "bin"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "publish:public": "npm publish --access public"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "ifreeicloud",
    "imei",
    "imei-check",
    "icloud",
    "fmi",
    "carrier-check",
    "blacklist",
    "esn",
    "claude-code",
    "ai-skill",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HOPLAtools/ifreeicloud"
  }
}
